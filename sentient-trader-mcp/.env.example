# sentient-trader-mcp — required credentials
# Copy to .env (or ~/.sentient-trader/config.env) and fill in your values.
# The server checks these paths on startup (in order):
#   1. ~/.sentient-trader/config.env
#   2. .env.local  (same dir as server)
#   3. .env        (same dir as server)

# ── Kalshi API credentials (required for place_trade, get_balance, get_positions, cancel_order) ──
KALSHI_API_KEY=your-kalshi-api-key-id
KALSHI_PRIVATE_KEY_PATH=/path/to/kalshi_private_key.pem

# ── Strategy tuning (optional — these are the defaults) ──
# MARKOV_MIN_GAP=0.11      # minimum P(YES) gap from 0.5 to enter (directional conviction)
# MIN_PERSIST=0.82         # minimum Markov persistence required
# MAX_ENTRY_PRICE=72       # ¢ — price cap; 73¢+ zone has no edge after fees
# MAX_VOL_MULT=1.25        # max GK vol relative to 0.002 baseline before blocking
# MIN_HURST=0.50           # Hurst exponent floor — below 0.5 = mean-reverting, skip
